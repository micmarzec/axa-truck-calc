// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Certificate {
  id              Int      @id @default(autoincrement())
  numerCertyfikatu String   @unique
  numerUmowy      String
  daneKlienta     String   // Stores JSON payload of formData
  dataWystawienia DateTime @default(now())
  xmlWyslany      Boolean  @default(false)
  
  userId          Int?
  user            User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  calculationId   Int?
  calculation     Calculation? @relation(fields: [calculationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("USER") // 'ADMIN' or 'USER'
  signatureUrl String?
  createdAt DateTime @default(now())
  certificates Certificate[]
  calculations Calculation[]
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String   // Removed @unique to allow versioning ("Basic", "Top", "Best+")
  code      String   // "01", "02", "03"
  priceT6Z      Float
  priceT10Z     Float
  commissionT6Z Float    @default(0.0)
  commissionT10Z Float   @default(0.0)
  active        Boolean  @default(true)
  validFrom     DateTime @default(now())
  validTo       DateTime?

  // documents     ProductDocument[] - usunięte powiązanie
}

model Document {
  id          Int      @id @default(autoincrement())
  type        String   // 'OWU_SWU' lub 'IPID'
  fileUrl     String   // Sciezka do pliku
  validFrom   DateTime // Data obowiazywania
  createdAt   DateTime @default(now())
}

model Calculation {
  id               Int      @id @default(autoincrement())
  groupId          String   // Grupowanie wersji (uuid)
  version          Int      @default(1)
  daneKlienta      String   @db.Text // formData JSON
  wynikKalkulacji  String   @db.Text // calculation result JSON
  userId           Int
  user             User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt        DateTime @default(now())
  validUntil       DateTime
  certificates     Certificate[]
}

model SystemSettings {
  id                  Int    @id @default(1)
  partnerName         String @default("Pekao Leasing")
  partnerRegistryData String @db.Text
  
  xmlPartnerId        String @default("PEKAO_TA")
  sftpHost            String @default("")
  sftpPort            Int    @default(22)
  sftpUser            String @default("")
  sftpPassword        String @default("")
  
  insuranceName       String @default("Truck Assistance dla Klientów Pekao Leasing")
}
