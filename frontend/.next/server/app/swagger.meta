{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/swagger/layout,_N_T_/swagger/page,_N_T_/swagger"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/swagger/__PAGE__",
    "/swagger",
    "/_index",
    "/_head"
  ]
}